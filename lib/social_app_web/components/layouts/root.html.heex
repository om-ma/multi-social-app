<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="SocialApp">
      {assigns[:page_title]}
    </.live_title>
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        // Theme
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "dark");
        }

        // RTL toggle
        const dir = localStorage.getItem("phx:dir") || "ltr";
        document.documentElement.setAttribute("dir", dir);
        if (dir === "rtl") {
          document.documentElement.setAttribute("lang", "ar");
        }
        window.addEventListener("phx:toggle-rtl", () => {
          const current = document.documentElement.getAttribute("dir");
          const next = current === "rtl" ? "ltr" : "rtl";
          document.documentElement.setAttribute("dir", next);
          document.documentElement.setAttribute("lang", next === "rtl" ? "ar" : "en");
          localStorage.setItem("phx:dir", next);
        });
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
